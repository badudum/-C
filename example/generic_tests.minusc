Point = cust {
    {x} int;
    {y} int;
};

Showable = interface {
    readTag = (self) function {
        return 0;
    } int;
};

Box<T> = cust {
    {value} T;

    get = (self) function {
        return self.value;
    } T;
};

TaggedBox<T> = cust implements Showable {
    {value} T;

    virtual readTag = (self) function {
        return 1;
    } int;
};

readTagThrough = ({b} Showable) function {
    return b.readTag();
} int;

testGenericIntBox = ({x} int) function {
    HelloWorldLine("--- [generic-1] Box<int> field access ---");
    {b} Box<int> = {value=42};
    if (b.value == 42) {
        HelloWorldLine("PASS: Box<int> stores int");
    } else {
        HelloWorldLine("FAIL: Box<int> value=", b.value);
    };
    return 0;
} int;

testGenericCustBox = ({x} int) function {
    HelloWorldLine("--- [generic-2] Box<Point> distinct layout ---");
    {b} Box<Point> = {value=Point{x=3, y=4}};
    if (b.value.x == 3) {
        if (b.value.y == 4) {
            HelloWorldLine("PASS: Box<Point> nested cust field");
        } else {
            HelloWorldLine("FAIL: Box<Point> y field");
        };
    } else {
        HelloWorldLine("FAIL: Box<Point> x field");
    };
    return 0;
} int;

testGenericDistinct = ({x} int) function {
    HelloWorldLine("--- [generic-3] distinct monomorphized instances ---");
    {bi} Box<int> = {value=1};
    {bp} Box<Point> = {value=Point{x=10, y=20}};
    if (bi.value == 1) {
        if (bp.value.x == 10) {
            HelloWorldLine("PASS: Box_int and Box_Point distinct instances");
        } else {
            HelloWorldLine("FAIL: bp.value.x");
        };
    } else {
        HelloWorldLine("FAIL: bi.value");
    };
    return 0;
} int;

testGenericMethod = ({x} int) function {
    HelloWorldLine("--- [generic-4] generic cust method ---");
    {b} Box<int> = {value=42};
    if (b.get() == 42) {
        HelloWorldLine("PASS: Box<int> generic method get()");
    } else {
        HelloWorldLine("FAIL: Box<int> get()");
    };
    return 0;
} int;

testGenericImplements = ({x} int) function {
    HelloWorldLine("--- [generic-5] generic template implements interface ---");
    {b} TaggedBox<int> = {value=55};
    {v} int = readTagThrough(b);
    if (v == 1) {
        HelloWorldLine("PASS: TaggedBox<int> stack value via Showable");
    } else {
        HelloWorldLine("FAIL: generic iface v=", v);
    };
    return 0;
} int;

testGenericOps = ({x} int) function {
    testGenericIntBox(0);
    testGenericCustBox(0);
    testGenericDistinct(0);
    testGenericMethod(0);
    testGenericImplements(0);
    return 0;
} int;
