testLoopUntil = ({x} int) function {
    HelloWorldLine("--- loop until & ++/-- tests ---");

    {count} int = 0;
    loop until (count < 3) {
        HelloWorldLine("while-style count=", count);
        count++;
    };

    HelloWorldLine("--- for-style: init in bracket ---");
    loop until ({i} int = 0; i < 3; i++) {
        HelloWorldLine("for i=", i);
    };

    HelloWorldLine("--- for-style: init outside ---");
    {j} int = 0;
    loop until (j = 0; j < 2; j++) {
        HelloWorldLine("for j=", j);
    };

    HelloWorldLine("--- do-while: run once then until ---");
    {n} int = 0;
    loop {
        HelloWorldLine("do-while body n=", n);
        n++;
    } until (n >= 2);

    HelloWorldLine("--- ++/-- prefix and postfix ---");
    {a} int = 5;
    {b} int = a++;
    HelloWorldLine("a++: a=", a, " b (old)=", b);
    {c} int = ++a;
    HelloWorldLine("++a: a=", a, " c (new)=", c);
    {d} int = 10;
    {e} int = d--;
    HelloWorldLine("d--: d=", d, " e (old)=", e);
    {f} int = --d;
    HelloWorldLine("--d: d=", d, " f (new)=", f);

    HelloWorldLine("--- += and -= ---");
    {x} int = 100;
    x += 10;
    HelloWorldLine("x += 10: x=", x);
    x -= 25;
    HelloWorldLine("x -= 25: x=", x);
    {sum} int = 0;
    loop until ({k} int = 0; k < 5; k++) {
        sum += k;
    };
    HelloWorldLine("sum 0+1+2+3+4 = ", sum);

    return 0;
} int;
