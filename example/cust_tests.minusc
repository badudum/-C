Point = cust {
    {x} int;
    {y} int;
};

Rect = cust {
    {origin} Point;
    {w} int;
    {h} int;
};

testCustBasic = ({x} int) function {
    HelloWorldLine("--- [cust-1] Point init and field access ---");
    {p} Point = Point{x=3, y=4};
    {sum} int = p.x + p.y;
    {sz} int = sizeof(Point);
    if (sum == 7 and sz == 8) {
        HelloWorldLine("PASS: Point typed init + fields + sizeof");
    } else {
        HelloWorldLine("FAIL: Point basic", sum, sz);
    };
    return 0;
} int;

testCustBareInit = ({x} int) function {
    HelloWorldLine("--- [cust-2] bare brace init ---");
    {p} Point = {x=10, y=5};
    if (p.x == 10 and p.y == 5) {
        HelloWorldLine("PASS: bare cust init");
    } else {
        HelloWorldLine("FAIL: bare cust init");
    };
    return 0;
} int;

testCustFieldAssign = ({x} int) function {
    HelloWorldLine("--- [cust-3] field assignment ---");
    {p} Point = {x=1, y=2};
    p.x = 20;
    p.y = 22;
    if (p.x == 20 and p.y == 22) {
        HelloWorldLine("PASS: field assign");
    } else {
        HelloWorldLine("FAIL: field assign");
    };
    return 0;
} int;

testCustNested = ({x} int) function {
    HelloWorldLine("--- [cust-4] nested cust ---");
    {r} Rect = Rect{origin=Point{x=1, y=2}, w=30, h=40};
    {ox} int = r.origin.x;
    {oy} int = r.origin.y;
    {area} int = r.w * r.h;
    if (ox == 1 and oy == 2 and area == 1200 and sizeof(Rect) == 16) {
        HelloWorldLine("PASS: nested cust");
    } else {
        HelloWorldLine("FAIL: nested cust", ox, oy, area);
    };
    return 0;
} int;

testCustCopy = ({x} int) function {
    HelloWorldLine("--- [cust-5] cust copy assign ---");
    {a} Point = {x=5, y=6};
    {b} Point = a;
    if (b.x == 5 and b.y == 6) {
        HelloWorldLine("PASS: cust copy");
    } else {
        HelloWorldLine("FAIL: cust copy");
    };
    return 0;
} int;

Blob = cust {
    {data} adr;
    {tag} int;
};

Pair = cust {
    {left} Blob;
    {right} Blob;
};

testCustNestedPair = ({x} int) function {
    HelloWorldLine("--- [cust-6] dual nested Blob fields in Pair ---");
    {p} Pair = Pair{
        left=Blob{data=rent(16), tag=10},
        right=Blob{data=rent(16), tag=20}
    };
    PokeInt(p.left.data, 0, 100);
    PokeInt(p.right.data, 0, 200);
    {lv} int = PeekInt(p.left.data, 0);
    {rv} int = PeekInt(p.right.data, 0);
    {lt} int = p.left.tag;
    {rt} int = p.right.tag;
    {fl} int = moveOut(p.left.data);
    {fr} int = moveOut(p.right.data);
    if (lv == 100 and rv == 200 and lt == 10 and rt == 20 and fl == 0 and fr == 0) {
        HelloWorldLine("PASS: nested Pair Blob inits");
    } else {
        HelloWorldLine("FAIL: nested Pair lv=", lv, " rv=", rv);
    };
    return 0;
} int;

Vec2 = class {
    {x} int;
    {y} int;
};

testCustClassKeyword = ({x} int) function {
    HelloWorldLine("--- [cust-7] class keyword alias for cust ---");
    {v} Vec2 = Vec2{x=7, y=8};
    {sz} int = sizeof(Vec2);
    if (v.x == 7 and v.y == 8 and sz == 8) {
        HelloWorldLine("PASS: class keyword type");
    } else {
        HelloWorldLine("FAIL: class keyword");
    };
    return 0;
} int;

testCustStandaloneBlock = ({x} int) function {
    HelloWorldLine("--- [cust-8] standalone braced block ---");
    {outer} int = 1;
    {captured} int = 0;
    {
        {inner} int = 99;
        captured = inner;
    };
    if (captured == 99 and outer == 1) {
        HelloWorldLine("PASS: standalone block scope");
    } else {
        HelloWorldLine("FAIL: block captured=", captured, " outer=", outer);
    };
    return 0;
} int;

testCustRentHeap = ({x} int) function {
    HelloWorldLine("--- [cust-9] rent(1, Point) heap layout ---");
    {sz} int = sizeof(Point);
    {heap} adr = rent(1, Point);
    PokeInt(heap, 0, 42);
    PokeInt(heap, 4, 58);
    {vx} int = PeekInt(heap, 0);
    {vy} int = PeekInt(heap, 4);
    {fd} int = moveOut(heap);
    if (sz == 8 and vx == 42 and vy == 58 and fd == 0) {
        HelloWorldLine("PASS: heap Point via rent(1, Point)");
    } else {
        HelloWorldLine("FAIL: rent heap sz=", sz, " vx=", vx, " vy=", vy);
    };
    return 0;
} int;

Scores = cust {
    {id} int;
    {base} Array<int>;
};

testCustArrayField = ({x} int) function {
    HelloWorldLine("--- [cust-10] Array<int> field in cust ---");
    {s} Scores = Scores{id=1, base=[5, 10, 15]};
    {id} int = s.id;
    {v0} int = s.base[0];
    {v2} int = s.base[2];
    {sz} int = sizeof(Scores);
    if (id == 1 and v0 == 5 and v2 == 15 and sz == 8) {
        HelloWorldLine("PASS: cust Array<int> field");
    } else {
        HelloWorldLine("FAIL: array field id=", id, " v0=", v0);
    };
    return 0;
} int;

testCustOps = ({x} int) function {
    HelloWorldLine("========================================");
    HelloWorldLine("     CUST TYPE TEST SUITE");
    HelloWorldLine("========================================");

    {a} int = testCustBasic(0);
    {b} int = testCustBareInit(0);
    {c} int = testCustFieldAssign(0);
    {d} int = testCustNested(0);
    {e} int = testCustCopy(0);
    {f} int = testCustNestedPair(0);
    {g} int = testCustClassKeyword(0);
    {h} int = testCustStandaloneBlock(0);
    {i} int = testCustRentHeap(0);
    {j} int = testCustArrayField(0);

    HelloWorldLine("========================================");
    HelloWorldLine("     CUST TESTS COMPLETE");
    HelloWorldLine("========================================");
    return 0;
} int;
