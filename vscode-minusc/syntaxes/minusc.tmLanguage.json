{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "minusC",
  "scopeName": "source.minusc",
  "patterns": [
    { "include": "#strings" },
    { "include": "#reference" },
    { "include": "#comment-line" },
    { "include": "#comment-block" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#literals" },
    { "include": "#operators" },
    { "include": "#numbers" }
  ],
  "repository": {
    "reference": {
      "name": "meta.preprocessor.reference.minusc",
      "match": "^\\s*(reference)\\b",
      "captures": {
        "1": { "name": "keyword.control.import.minusc" }
      }
    },
    "comment-line": {
      "name": "comment.line.double-slash.minusc",
      "match": "//[^\\n]*"
    },
    "comment-block": {
      "begin": "\\b(comment)\\s*:",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.comment.minusc" }
      },
      "end": ";",
      "name": "comment.block.minusc",
      "patterns": [{ "include": "#strings" }]
    },
    "strings": {
      "name": "string.quoted.double.minusc",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.minusc",
          "match": "\\\\."
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.minusc",
          "match": "\\b(if|else|return|loop|until|function)\\b"
        },
        {
          "name": "keyword.operator.logical.minusc",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.minusc",
          "match": "\\b(int|str|bool)\\b"
        },
        {
          "name": "storage.type.generic.minusc",
          "match": "\\bArray\\b"
        }
      ]
    },
    "literals": {
      "patterns": [
        {
          "name": "constant.language.boolean.minusc",
          "match": "\\b(Real|Fake)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.minusc",
          "match": "(\\+=|-=|==|!=|<=|>=|\\+\\+|--)"
        },
        {
          "name": "keyword.operator.minusc",
          "match": "[+\\-*/%<>=!&|^~]"
        },
        {
          "name": "punctuation.terminator.statement.minusc",
          "match": ";"
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.integer.minusc",
      "match": "\\b[0-9]+\\b"
    }
  }
}
