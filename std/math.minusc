AbsInt = ({x} int) function {
    if (x < 0) {
        return 0 - x;
    };
    return x;
} int;

MaxInt = ({a} int, {b} int) function {
    if (a >= b) {
        return a;
    };
    return b;
} int;

MinInt = ({a} int, {b} int) function {
    if (a <= b) {
        return a;
    };
    return b;
} int;
